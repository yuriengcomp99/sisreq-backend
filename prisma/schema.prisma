generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
}

enum EmpenhoTipo {
  ORDINARIO
  ESTIMATIVO
  GLOBAL
}

enum SimNao {
  SIM
  NAO
}

model User {
  id           String   @id @default(uuid())
  first_name   String
  army_name    String
  graduation   String

  designationId String
  designation   Designation @relation(fields: [designationId], references: [id])

  role         UserRole @default(USER)

  email        String   @unique
  password     String
  om           String   @default("BCMS")
  createdAt    DateTime @default(now())
}

model Designation {
  id        String   @id @default(uuid())
  position  String
  createdAt DateTime @default(now())

  users     User[]
}

model AtaItem {
  id                String   @id @default(uuid())

  pregao            String
  objeto            String 

  ugg               String
  nrAta             String
  nrItem            String

  descricao         String
  fornecedor        String

  inicioVigAta      DateTime
  fimVigAta         DateTime

  valorUnitario     Float

  uasg              String
  tipoUasg          String

  qtdHomologada     Int
  qtdAutorizada     Int
  qtdSaldo          Int

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([pregao, ugg, nrAta, nrItem])

}

model Requisicao {
  id                      String   @id @default(uuid())

  numero_diex             String
  nup                     String
  data_req                DateTime

  de                      String
  para                    String
  assunto                 String

  tipo                    String

  nr_pregao               String
  ug                      String
  nome_da_ug              String

  descricao_necessidade   String   @db.VarChar(500)

  recurso_id              Int

  empenho_tipo            EmpenhoTipo
  contrato                SimNao

  classe_grupo_pca        String
  nr_contratacao_pca      String

  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  detalhes                RequisicaoDetalhe[]
}

model RequisicaoDetalhe {
  id                String   @id @default(uuid())

  requisicaoId      String
  requisicao        Requisicao @relation(fields: [requisicaoId], references: [id])

  nr_item           String
  descricao         String
  subitem           String
  und               String

  qtd               Int
  valor_unitario    Float
  valor_total       Float

  createdAt         DateTime @default(now())
}